				<grains>
					<li Class="AudioGrain_Clip">
						<clipPath>unit_call</clipPath>
					</li>
				</grains>
				<volumeRange>20</volumeRange>
				<pitchRange>0.95~1.05</pitchRange>
				<sustainLoop>False</sustainLoop>
			</li>
		</subSounds>
	</SoundDef>

