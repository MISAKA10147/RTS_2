<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<ThingDef ParentName="EM_MediumUnit">
		<defName>EM_MUGV_HEL</defName>
		<label>MUGV_HEL</label>
		<description>Medium attack unit1.</description>
		<statBases>
			<MoveSpeed>6</MoveSpeed>
			<!-- 移动速度 -->
			<ShootingAccuracyPawn>20</ShootingAccuracyPawn>
			<Mass>200</Mass>
		</statBases>
		<comps>
			<li Class="RTS.UnitCompProperties">
				<mass>200</mass>
				<cost>20</cost>
			</li>
			<li Class="RTS.CompProperties_TurretGun">
				<!-- 添加炮塔枪组件 -->
				<turretDef>EM_MUGV_HEL_Turret</turretDef>
				<littleCooldown>1</littleCooldown>
				<!-- 连射冷却 -->
				<extraShootCount>4</extraShootCount>
				<!-- 额外射击次数 -->
				<warmupTime>10</warmupTime>
				<!-- 冷却时间 -->
				<angleOffset>-90</angleOffset>
				<autoAttack>false</autoAttack>
				<renderNodeProperties>
					<li>
						<nodeClass>RTS.PawnRenderNode_TurretGun</nodeClass>
						<workerClass>RTS.PawnRenderNodeWorker_TurretGun</workerClass>
						<overrideMeshSize>(2.1, 2.1)</overrideMeshSize>
						<parentTagDef>Body</parentTagDef>
						<baseLayer>20</baseLayer>
						<pawnType>Any</pawnType>
						<drawData>
							<dataWest>
								<rotationOffset>180</rotationOffset>
							</dataWest>
						</drawData>
					</li>
				</renderNodeProperties>
			</li>
		</comps>
		<killedLeavingsPlayerHostile>
			<Steel>50</Steel>
		</killedLeavingsPlayerHostile>
	</ThingDef>


	<PawnKindDef ParentName="EM_MediumUnitKind">
		<defName>EM_MUGV_HEL</defName>
		<label>MUGV_HEL</label>
		<labelPlural>MUGV_HEL</labelPlural>
		<race>EM_MUGV_HEL</race>
		<weaponTags>
		</weaponTags>
	</PawnKindDef>




	<ThingDef ParentName="BaseWeaponTurret">
		<defName>EM_MUGV_HEL_Turret</defName>
		<label>MUGV_HEL_Turret</label>
		<description>MUGV_HEL_Turret.</description>
		<tradeability>None</tradeability>
		<!-- 无法交易 -->
		<destroyOnDrop>true</destroyOnDrop>
		<!-- 抛弃时销毁 -->
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponRanged/EM_MUGV_HEL_Turret/EM_MUGV_HEL_Turret</texPath>
			<graphicClass>EM.Graphic_Turret_16Dir</graphicClass>
		</graphicData>
		<statBases>
			<Mass>2.6</Mass>
			<!-- 质量为 2.6 单位 -->
			<AccuracyTouch>1.00</AccuracyTouch>
			<!-- 触摸精度为 0.60 -->
			<AccuracyShort>1.00</AccuracyShort>
			<!-- 短距离精度为 0.80 -->
			<AccuracyMedium>1.00</AccuracyMedium>
			<!-- 中距离精度为 0.90 -->
			<AccuracyLong>1.00</AccuracyLong>
			<!-- 长距离精度为 0.85 -->
		</statBases>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<defaultProjectile>EM_Bullet_HEL</defaultProjectile>
				<warmupTime>0</warmupTime>
				<range>30</range>
				<burstShotCount>1</burstShotCount>
				<ticksBetweenBurstShots>1</ticksBetweenBurstShots>
				<soundCastTail>GunTail_Medium</soundCastTail>
				<muzzleFlashScale>6</muzzleFlashScale>
				<aimingChargeMote>Mote_BeamRepeater_Charge</aimingChargeMote>
				<aimingChargeMoteOffset>1.1</aimingChargeMoteOffset>
			</li>
		</verbs>
	</ThingDef>




</Defs>