<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- 单位底盘 -->

	<ThingDef ParentName="BasePawn" Name="EM_BaseUnit" Abstract="True">
		<soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
		<statBases>
			<MarketValue>2500</MarketValue>
			<!-- 心灵敏感度 -->
			<PsychicSensitivity>0</PsychicSensitivity>
			<!-- 毒素抗性 -->
			<ToxicResistance>1</ToxicResistance>
			<!--可燃性 -->
			<Flammability>0</Flammability>
			<!-- 舒适温度下限 -->
			<ComfyTemperatureMin>-164</ComfyTemperatureMin>
			<!-- 舒适温度上限 -->
			<ComfyTemperatureMax>1400</ComfyTemperatureMax>
			<!-- 肉量 -->
			<MeatAmount>0</MeatAmount>
			<!-- 热能护甲 -->
			<ArmorRating_Heat>4.00</ArmorRating_Heat>
			<!-- 带宽成本 -->
			<BandwidthCost MayRequire="Ludeon.RimWorld.Biotech">0</BandwidthCost>
			<!-- 控制所需时间 -->
			<ControlTakingTime MayRequire="Ludeon.RimWorld.Biotech">12</ControlTakingTime>
			<!-- 有毒环境抗性 -->
			<ToxicEnvironmentResistance>1</ToxicEnvironmentResistance>
			<!-- 每点生命值损失能量 -->
			<MechEnergyLossPerHP MayRequire="Ludeon.RimWorld.Biotech">0.1</MechEnergyLossPerHP>
			<!-- 每次充电产生的废料包 -->
			<WastepacksPerRecharge MayRequire="Ludeon.RimWorld.Biotech">0</WastepacksPerRecharge>
			<!-- 全局工作速度 -->
			<WorkSpeedGlobal MayRequire="Ludeon.RimWorld.Biotech">1</WorkSpeedGlobal>
		</statBases>
		<comps>
			<li Class="VEF.AnimalBehaviours.CompProperties_Draftable">
				<makeNonFleeingToo>true</makeNonFleeingToo>
			</li>
		</comps>
		<!-- 是否接收信号（指令） -->
		<receivesSignals>true</receivesSignals>
		<!-- 交易能力 -->
		<tradeability>None</tradeability>
		<race>
			<!-- 永远清醒 -->
			<alwaysAwake>true</alwaysAwake>
			<!-- 血肉类型 -->
			<fleshType>Drone</fleshType>
			<!-- 是否需要休息 -->
			<needsRest>false</needsRest>
			<!-- 是否有性别 -->
			<hasGenders>false</hasGenders>
			<!-- 食物类型 -->
			<foodType>None</foodType>
			<!-- 预期寿命 -->
			<lifeExpectancy>2500</lifeExpectancy>
			<!-- 血液定义 -->
			<bloodDef>Filth_MachineBits</bloodDef>
			<!-- 禁用点燃动作 -->
			<disableIgniteVerb>true</disableIgniteVerb>
			<!-- 名称生成器 -->
			<nameGenerator MayRequire="Ludeon.RimWorld.Biotech">NamerMech</nameGenerator>
			<!-- 隐藏训练标签页 -->
			<hideTrainingTab>true</hideTrainingTab>
			<!-- 叫声间隔范围 -->
			<soundCallIntervalRange>1000~2000</soundCallIntervalRange>
			<!-- 对友方的叫声间隔倍数因子 -->
			<soundCallIntervalFriendlyFactor>2</soundCallIntervalFriendlyFactor>
			<!-- 思考树 -->
			<thinkTreeConstant MayRequire="Ludeon.RimWorld.Biotech">UnitConstant</thinkTreeConstant>
			<!-- 是否能在真空中飞行-->
			<canFlyInVacuum>true</canFlyInVacuum>
		</race>
		<killedLeavings>
			<Filth_MachineBits>4</Filth_MachineBits>
			<!-- 死亡留下4个机器碎屑污渍 -->
		</killedLeavings>
		<comps>
			<!-- 机械可修复组件 -->
			<!--<li MayRequire="Ludeon.RimWorld.Biotech" Class="CompProperties_MechRepairable" /> -->
		</comps>
	</ThingDef>

	<PawnKindDef Name="EM_BaseUnitKind" Abstract="True">
		<!-- AI规避掩体 -->
		<aiAvoidCover>true</aiAvoidCover>
		<!-- 默认派系 -->
		<defaultFactionDef>Mechanoid</defaultFactionDef>
		<!-- AI是否避免掩体 -->
		<aiAvoidCover>true</aiAvoidCover>
		<!-- 掉落时是否销毁装备 -->
		<destroyGearOnDrop>true</destroyGearOnDrop>
		<!-- 是否可以被扒光 -->
		<canStrip>false</canStrip>
		<!-- 最小生成年龄为200 -->
		<minGenerationAge MayRequire="Ludeon.RimWorld.Biotech">1</minGenerationAge>
		<!-- 是否强制普通装备品质 -->
		<forceNormalGearQuality>true</forceNormalGearQuality>
		<!-- 生成武器预算 -->
		<weaponMoney>9999~9999</weaponMoney>
		<!-- 战斗力。 -->
		<combatPower>5</combatPower>
		<!-- 武器标签 -->
		<weaponTags></weaponTags>
		<!-- 安装Hediff概率 -->
		<techHediffsChance>1</techHediffsChance>
		<!-- 预算 -->
		<techHediffsMoney>9999~9999</techHediffsMoney>
		<!-- 控制组缩放比例 -->
		<controlGroupPortraitZoom>1.8</controlGroupPortraitZoom>

		<allowInMechClusters>false</allowInMechClusters>
		<!-- 不允许加入机甲集群 -->
		<forceNoDeathNotification>true</forceNoDeathNotification>
		<!-- 强制不发送死亡通知 -->
		<forceDeathOnDowned>true</forceDeathOnDowned>
		<!-- 被击倒后立即死亡 -->
		<allowOldAgeInjuries>false</allowOldAgeInjuries>
		<!-- 不允许因衰老而受伤 -->
		<!-- 意识形态阻止 -->
		<preventIdeo>true</preventIdeo>
		<!-- 游戏状态免疫 -->
		<immuneToGameConditionEffects>true</immuneToGameConditionEffects>
		<!-- 编队头像缩放 -->
		<canOpenDoors>false</canOpenDoors>
	</PawnKindDef>









	
	
	
	
	
	
	




	<ThingDef Name="EM_DroneUnit" ParentName="EM_BaseUnit" Abstract="True">
		<statBases>
			<!-- 市场价值 -->
			<MarketValue>50</MarketValue>
			<MoveSpeed>10</MoveSpeed>
			<!--钝器护甲 -->
			<ArmorRating_Blunt>0.50</ArmorRating_Blunt>
			<!-- 利器护甲 -->
			<ArmorRating_Sharp>0.30</ArmorRating_Sharp>
			<!-- 1点HP消耗能量 -->
			<MechEnergyLossPerHP>0</MechEnergyLossPerHP>
		</statBases>
		<race>
			<body>EM_Unit_Light</body>
			<baseBodySize>1</baseBodySize>
			<baseHealthScale>0.3</baseHealthScale>
			<!-- 基础生命值比例 -->
			<hasCorpse>false</hasCorpse>
			<!-- 无尸体 -->
			<deathAction>
				<workerClass>DeathActionWorker_SmallExplosion</workerClass>
				<!-- 死亡动作类 -->
			</deathAction>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>0</minAge>
					<soundWounded>EM_Unit_Wounded</soundWounded>
					<!-- 受伤时的声音 -->
					<soundDeath>EM_Unit_Death</soundDeath>
					<!-- 死亡时的声音 -->
					<soundCall>EM_Unit_Call</soundCall>
					<!-- 叫声 -->
				</li>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>100</minAge>
					<!-- 最小年龄为 100 -->
					<soundWounded>EM_Unit_Wounded</soundWounded>
					<!-- 受伤时的声音 -->
					<soundDeath>EM_Unit_Death</soundDeath>
					<!-- 死亡时的声音 -->
					<soundCall>EM_Unit_Call</soundCall>
					<!-- 叫声 -->
				</li>
			</lifeStageAges>
			<!-- 智能等级 -->
			<intelligence>ToolUser</intelligence>
			<!-- 思考树 -->
			<thinkTreeMain>Mechanoid</thinkTreeMain>
			<!-- 基础体型 -->
			<baseBodySize>0.2</baseBodySize>
			<!-- 重量分类 -->
			<mechWeightClass>Light</mechWeightClass>
		</race>
		<!-- 屠宰机械体 -->
		<butcherProducts>
			<Steel>1</Steel>
		</butcherProducts>
		<tools>
			<li>
				<label>head</label>
				<capacities>
					<li>Blunt</li>
				</capacities>
				<!-- 攻击力 -->
				<power>6</power>
				<!-- 攻击间隔 -->
				<cooldownTime>3</cooldownTime>
				<!-- 关联身体部件 -->
				<linkedBodyPartsGroup>HeadAttackTool</linkedBodyPartsGroup>
				<!-- 受损攻击也进行 -->
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
		</tools>
	</ThingDef>

	<PawnKindDef Name="EM_DroneUnitKind" ParentName="EM_BaseUnitKind" Abstract="True">
		<!-- 战斗力。 -->
		<combatPower>5</combatPower>
		<lifeStages>
		</lifeStages>
	</PawnKindDef>









	
	
	









