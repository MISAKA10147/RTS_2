<?xml version="1.0" encoding="utf-8"?>
<Defs>

	<ThingDef ParentName="EM_Walking_LightUnit">
		<defName>EM_LightWalkingUnit_EMRG</defName>
		<label>LightWalkingUnit_EMRG</label>
		<description>Light attack unit1.</description>
		<statBases>
			<MoveSpeed>5</MoveSpeed>
			<!-- 移动速度 -->
			<Mass>60</Mass>
			<ShootingAccuracyPawn>20</ShootingAccuracyPawn>
		</statBases>
		<comps>
			<li Class="RTS.UnitCompProperties">
				<mass>20</mass>
				<cost>5</cost>
			</li>
			<li Class="RTS.CompProperties_TurretGun">
				<!-- 添加炮塔枪组件 -->
				<turretDef>EM_LightWalkingUnit_EMRG_Turret</turretDef>
				<littleCooldown>0</littleCooldown>
				<!-- 连射冷却 -->
				<extraShootCount>0</extraShootCount>
				<!-- 额外射击次数 -->
				<warmupTime>100</warmupTime>
				<!-- 冷却时间 -->
				<angleOffset>-90</angleOffset>
				<autoAttack>false</autoAttack>
				<renderNodeProperties>
					<li>
						<nodeClass>RTS.PawnRenderNode_TurretGun</nodeClass>
						<workerClass>RTS.PawnRenderNodeWorker_TurretGun</workerClass>
						<overrideMeshSize>(3.8, 3.8)</overrideMeshSize>
						<parentTagDef>Body</parentTagDef>
						<baseLayer>20</baseLayer>
						<pawnType>Any</pawnType>
						<drawData>
							<dataWest>
								<rotationOffset>180</rotationOffset>
							</dataWest>
						</drawData>
					</li>
				</renderNodeProperties>
			</li>
			<li Class="EM.CompProperties_JumpLauncher">
				<maxCharges>3</maxCharges>
				<cooldownTicks>1800</cooldownTicks>
				<!-- 30秒/格 -->
				<jumpRange>25</jumpRange>
				<minRange>0</minRange>
				<warmupTicks>60</warmupTicks>
				<!-- 1秒暖机 -->
				<targeterRadius>25</targeterRadius>
				<jumpSound>Longjump_Launch</jumpSound>
				<jumpEffectMote>Mote_JumpFlash</jumpEffectMote>
			</li>
		</comps>
		<killedLeavingsPlayerHostile>
			<Steel>50</Steel>
		</killedLeavingsPlayerHostile>
	</ThingDef>


	<PawnKindDef ParentName="EM_Walking_LightUnitKind">
		<defName>EM_LightWalkingUnit_EMRG</defName>
		<label>LightWalkingUnit_EMRG</label>
		<labelPlural>LightWalkingUnit_EMRG</labelPlural>
		<race>EM_LightWalkingUnit_EMRG</race>
		<weaponTags>
		</weaponTags>
	</PawnKindDef>




	<ThingDef ParentName="BaseWeaponTurret">
		<defName>EM_LightWalkingUnit_EMRG_Turret</defName>
		<label>LightWalkingUnit_EMRG_Turret</label>
		<description>LightWalkingUnit_EMRG_Turret.</description>
		<tradeability>None</tradeability>
		<!-- 无法交易 -->
		<destroyOnDrop>true</destroyOnDrop>
		<!-- 抛弃时销毁 -->
		<graphicData>
			<texPath>Things/Item/Equipment/WeaponRanged/EM_LightWalkingUnit_EMRG_Turret</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
			<Mass>3.6</Mass>
			<!-- 质量为 2.6 单位 -->
			<AccuracyTouch>1.00</AccuracyTouch>
			<!-- 触摸精度为 0.60 -->
			<AccuracyShort>1.00</AccuracyShort>
			<!-- 短距离精度为 0.80 -->
			<AccuracyMedium>1.00</AccuracyMedium>
			<!-- 中距离精度为 0.90 -->
			<AccuracyLong>1.00</AccuracyLong>
			<!-- 长距离精度为 0.85 -->
		</statBases>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<!-- 动作类 -->
				<defaultProjectile>EM_Bullet_LightWalkingUnit_EMRG</defaultProjectile>
				<!-- 弹药类型 -->
				<forcedMissRadius>0.01</forcedMissRadius>
				<range>80</range>
				<!-- 射程 -->
				<soundCast>EM_ATlaunch</soundCast>
				<!-- 发射时的声音效果 -->
				<soundCastTail>GunTail_Heavy</soundCastTail>
				<!-- 发射尾声声音效果 -->
				<muzzleFlashScale>9</muzzleFlashScale>
				<!-- 枪口闪光比例 -->
				<defaultCooldownTime>0</defaultCooldownTime>
				<!-- 冷却时间 -->
				<warmupTime>0</warmupTime>
				<!-- 准备射击的时间 -->
				<linkedBodyPartsGroup>BulbTurret</linkedBodyPartsGroup>
				<!-- 关联的身体部位组 BulbTurret -->
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
				<!-- 确保关联的身体部位组始终可用 -->
				<ticksBetweenBurstShots>0</ticksBetweenBurstShots>
				<!-- 连射间隔 -->
				<burstShotCount>1</burstShotCount>
				<targetParams>
					<canTargetLocations>true</canTargetLocations>
				</targetParams>
				<!-- 准备发射声音 -->
				<soundAiming>EM_AT_Aiming</soundAiming>
				<!-- 最小射程 -->
				<minRange>1</minRange>
				<!-- 目标特效 -->
				<aimingTargetMote>Mote_HellsphereCannon_Target</aimingTargetMote>
				<!-- AI 避免友军火力半径 -->
				<ai_AvoidFriendlyFireRadius>6</ai_AvoidFriendlyFireRadius>
				<!-- AI 是建筑破坏者 -->
				<ai_IsBuildingDestroyer>true</ai_IsBuildingDestroyer>
			</li>
		</verbs>
	</ThingDef>

</Defs>