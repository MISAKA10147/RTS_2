<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<!-- 固定生产建设单元 -->
	<ThingDef ParentName="BuildingBase">
		<defName>EM_FortressFactory</defName>
		<label>堡垒工厂</label>
		<description>堡垒工厂.</description>
		<thingClass>Building</thingClass>
		<!-- 地图网格和实时渲染 -->
		<drawerType>MapMeshAndRealTime</drawerType>
		<graphicData>
			<texPath>Things/Building/FortressFactory/EM_FortressFactory</texPath>
			<graphicClass>Graphic_Multi</graphicClass>
			<drawSize>(11,11)</drawSize>
			<shadowData>
				<volume>(5,0.1,5)</volume>
				<offset>(0,0,0)</offset>
			</shadowData>
			<damageData>
				<rect>(0,0.6,4,2.8)</rect>
			</damageData>
		</graphicData>
		<!-- 是否投射边缘阴影 -->
		<castEdgeShadows>false</castEdgeShadows>
		<!-- 是否可以旋转 -->
		<rotatable>true</rotatable>
		<!-- 海拔层 -->
		<altitudeLayer>Building</altitudeLayer>
		<!-- 通过性 -->
		<passability>PassThroughOnly</passability>
		<!-- 移动成本 -->
		<pathCost>50</pathCost>
		<!-- 填充百分比 -->
		<fillPercent>0.4</fillPercent>
		<!-- 是否可以重叠区域 -->
		<canOverlapZones>false</canOverlapZones>
		<!-- 基础统计数据 -->
		<statBases>
			<!-- 最大生命值 -->
			<MaxHitPoints>8000</MaxHitPoints>
			<!-- 构建所需工作量 -->
			<WorkToBuild>2500</WorkToBuild>
			<!-- 易燃性 -->
			<Flammability>0.1</Flammability>
		</statBases>
		<!-- 计时器类型 -->
		<tickerType>Normal</tickerType>
		<!-- 大小 -->
		<size>(7,8)</size>
		<building>
			<!-- 破坏声音 -->
			<destroySound>BuildingDestroyed_Metal_Big</destroySound>
		</building>
		<!-- 成本列表 -->
		<costList>
			<Steel>200</Steel>
		</costList>
		<!-- 组件列表 -->
		<inspectorTabs>
			<li>RTS.ITab_HiveSystem</li>
		</inspectorTabs>
		<comps>
			<!-- 发光组件属性 -->
			<li Class="CompProperties_Glower">
				<!-- 发光半径 -->
				<glowRadius>6</glowRadius>
				<!-- 发光颜色 -->
				<glowColor>(255,200,80,0)</glowColor>
				<!-- 是否启用颜色选择器 -->
				<colorPickerEnabled>false</colorPickerEnabled>
				<!-- 是否启用暗光切换 -->
				<darklightToggle>false</darklightToggle>
			</li>
			<!-- 动力组件 -->
			<li Class="CompProperties_Power">
				<compClass>CompPowerTrader</compClass>
				<shortCircuitInRain>true</shortCircuitInRain>
				<basePowerConsumption>-500</basePowerConsumption>
			</li>
			<!-- 可被打断组件 -->
			<li Class="CompProperties_Stunnable">
				<useLargeEMPEffecter>true</useLargeEMPEffecter>
				<!-- 每刻钟受到EMP攻击的概率 -->
				<empChancePerTick>0.03</empChancePerTick>
				<!-- 影响的伤害类型 -->
				<affectedDamageDefs>
					<li>EMP</li>
				</affectedDamageDefs>
			</li>
			<li Class="RTS.CompPropertiesHiveSystem">
				<costLimit>2000</costLimit>
				<!-- 人口 -->
				<massLimit>4000</massLimit>
				<!-- 质量库存 -->
				<massPerCount>1</massPerCount>
				<!-- 钢铁对应的Mass -->
				<healInterval>400</healInterval>
				<!-- 维修间隔tick -->
				<healMassPerUnit>100</healMassPerUnit>
				<!-- 每个单元消耗的质量 -->
				<healPointPerMass>5</healPointPerMass>
				<!-- 每个质量对应的点数 -->
				<massToRestorePart>5</massToRestorePart>
				<!-- 肢体再生 -->
				<recyclePercent>0.5</recyclePercent>
				<!-- 销毁返还资源 -->
				<units>
					<li>
						<kind>EM_Bomb_Drone</kind>
						<spawnTime>20</spawnTime>
						<type>RTS_SpecialUnits</type>
						<unitDesc>Light attack unit1</unitDesc>
						<iconPath>UI/units/boom</iconPath>
					</li>
					<li>
						<kind>EM_LUGV_MG</kind>
						<spawnTime>200</spawnTime>
						<type>RTS_LightUnits</type>
						<unitDesc>Light attack unit1</unitDesc>
						<iconPath>UI/units/L_UGV_MG</iconPath>
						<traits>
							<li>RTS_Vacuum</li>
						</traits>
					</li>
					<li>
						<kind>EM_LightWalkingUnit_RP</kind>
						<spawnTime>600</spawnTime>
						<type>RTS_LightUnits</type>
						<unitDesc>Light attack unit1</unitDesc>
						<iconPath>UI/units/L_UGV_RP</iconPath>
						<traits>
							<li>RTS_Vacuum</li>
						</traits>
					</li>
					<li>
						<kind>EM_LUGV_emp</kind>
						<spawnTime>400</spawnTime>
						<type>RTS_LightUnits</type>
						<unitDesc>Light attack unit1</unitDesc>
						<iconPath>UI/units/L_UGV_EMP</iconPath>
					</li>
					<li>
						<kind>EM_MUGV_RP</kind>
						<spawnTime>400</spawnTime>
						<type>RTS_MediumUnits</type>
						<unitDesc>Light attack unit1</unitDesc>
						<iconPath>UI/units/M_UGV_RP</iconPath>
					</li>
					<li>
						<kind>EM_MUGV_AP</kind>
						<spawnTime>400</spawnTime>
						<type>RTS_MediumUnits</type>
						<unitDesc>Light attack unit1</unitDesc>
						<iconPath>UI/units/M_UGV_AP</iconPath>
					</li>
					<li>
						<kind>EM_MUGV_HEL</kind>
						<spawnTime>400</spawnTime>
						<type>RTS_MediumUnits</type>
						<unitDesc>Light attack unit1</unitDesc>
						<iconPath>UI/units/M_UGV_HEL</iconPath>
					</li>
					<li>
						<kind>EM_MUGV_FT</kind>
						<spawnTime>400</spawnTime>
						<type>RTS_MediumUnits</type>
						<unitDesc>Light attack unit1</unitDesc>
						<iconPath>UI/units/M_UGV_FT</iconPath>
					</li>
					<li>
						<kind>EM_MCRU</kind>
						<spawnTime>400</spawnTime>
						<type>RTS_SpecialUnits</type>
						<unitDesc>Light attack unit1</unitDesc>
						<iconPath>UI/units/MCRU</iconPath>
					</li>
				</units>
			</li>
		</comps>
		<!-- 所需地形适配度 -->
		<terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
		<!-- 设计分类 -->
		<designationCategory>EM_Self-assemblyBuilding</designationCategory>
		<!-- UI排序顺序 -->
		<uiOrder>2100</uiOrder>
		<!-- 构造效果 -->
		<constructEffect>ConstructMetal</constructEffect>
		<uiIconScale>1</uiIconScale>
	</ThingDef>
	
</Defs>